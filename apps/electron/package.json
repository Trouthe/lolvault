{
  "name": "lolvault-electron",
  "version": "0.4.6",
  "main": "main.js",
  "author": "LoL Vault",
  "description": "League of Legends account manager and launcher",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "test": "ng test",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:4200 && electron .\"",
    "build-electron": "ng build && electron .",
    "dist:win": "ng build --configuration production && electron-builder --win --x64",
    "dist:mac": "ng build --configuration production && electron-builder --mac",
    "dist:all": "ng build --configuration production && electron-builder --win --x64 --mac",
    "release:win": "ng build --configuration production && dotenv -e .env -- electron-builder --win --x64 --publish always",
    "release:mac": "ng build --configuration production && dotenv -e .env -- electron-builder --mac --publish always",
    "release:all": "ng build --configuration production && dotenv -e .env -- electron-builder --win --x64 --mac --publish always"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.1.0",
    "@angular/router": "^21.1.0",
    "electron-updater": "^6.8.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.0",
    "@angular/cli": "^21.1.0",
    "@angular/compiler-cli": "^21.1.0",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "^21.1.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "electron": "39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "jasmine-core": "^5.13.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.lolvault.app",
    "productName": "LoL Vault",
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Trouthe",
        "repo": "lolvault"
      }
    ],
    "files": [
      "dist/lolvault/**/*",
      "main.js",
      "preload.js",
      "src/app/data/**/*",
      {
        "from": "../../node_modules",
        "to": "node_modules",
        "filter": [
          "electron-updater/**",
          "builder-util-runtime/**",
          "fs-extra/**",
          "graceful-fs/**",
          "jsonfile/**",
          "universalify/**",
          "js-yaml/**",
          "argparse/**",
          "lazy-val/**",
          "lodash.escaperegexp/**",
          "lodash.isequal/**",
          "semver/**",
          "tiny-typed-emitter/**",
          "debug/**",
          "ms/**",
          "sax/**"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "src/app/data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "LoLVaultSetup-${version}.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "identity": null
    },
    "dmg": {
      "icon": "build/icon.icns",
      "artifactName": "LoLVault-${version}.dmg"
    }
  }
}
